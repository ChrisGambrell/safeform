{
  "name": "@safeform/core",
  "version": "1.0.0",
  "description": "End-to-end type-safe forms for React",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "react",
    "form",
    "zod",
    "typescript",
    "validation",
    "typesafe",
    "react-hook-form"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ChrisGambrell/safeform.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/ChrisGambrell/safeform#readme",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "dev": "tsc --project tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0"
  },
  "peerDependencies": {
    "zod": "^3.0.0",
    "react": "^18.0.0",
    "react-hook-form": "^7.0.0"
  },
  "devDependencies": {
    "zod": "^3.24.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.56.1",
    "@types/react": "^18.3.22",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "jsdom": "^26.1.0",
    "vitest": "^3.1.2",
    "typescript": "^5.8.3"
  }
}
