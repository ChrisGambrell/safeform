{
  "name": "@safeform/next",
  "version": "1.0.0",
  "description": "Next.js App Router adapter for safeform",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "safeform",
    "next",
    "nextjs",
    "react",
    "form",
    "zod",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ChrisGambrell/safeform.git",
    "directory": "packages/next"
  },
  "homepage": "https://github.com/ChrisGambrell/safeform#readme",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "dev": "tsc --project tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@safeform/core": "*",
    "next": ">=14.0.0",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@safeform/core": "workspace:*",
    "zod": "^3.24.2",
    "vitest": "^3.1.2",
    "typescript": "^5.8.3"
  }
}
